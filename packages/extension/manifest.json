{
  "manifest_version": 3,
  "name": "BePresent",
  "version": "0.0.2",
  "short_name": "BePresent",
  "description": "Stay present — blocks distracting feeds on Instagram, YouTube, and X",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "service-worker.global.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.x.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content-script.global.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BePresent",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["icon-128.png"],
      "matches": [
        "*://*.instagram.com/*",
        "*://*.x.com/*",
        "*://*.youtube.com/*"
      ]
    }
  ]
}
